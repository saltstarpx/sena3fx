# ═══════════════════════════════════════════════════════
# YAGAMI改 MT5ボット 設定ファイル
# このファイルを .env にコピーして値を入力してください
# ═══════════════════════════════════════════════════════

# ── MT5接続設定 ──────────────────────────────────────
# Exness マイページ → 口座情報から確認できます
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=Exness-MT5Real8

# サーバー名の確認方法:
#   MT5ターミナル → ファイル → サーバーに接続 → 入力したサーバー名
# 主なExnessサーバー名:
#   Exness-MT5Real8  (リアル口座・標準)
#   Exness-MT5Real   (リアル口座・旧)
#   Exness-MT5Trial3 (デモ口座)

# ── Discord通知 ──────────────────────────────────────
# Discord → サーバー設定 → 連携サービス → ウェブフック から作成
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# ── リスク設定 ────────────────────────────────────────
BASE_RISK_PCT=0.02       # 基本リスク率: 2%（口座資金の2%をリスクにさらす）
MAX_POSITIONS=3          # 最大同時ポジション数

# ── ログ出力先 ────────────────────────────────────────
LOG_DIR=./trade_logs     # 取引ログの保存フォルダ

# ── ドライラン（模擬）設定 ────────────────────────────
# true: 実際の注文は出さずログのみ（テスト用）
# false: 実取引（本番）
DRY_RUN=false

# ── 口座残高（DRY_RUN=true の場合のみ使用） ───────────
EQUITY_JPY=1000000
