# deploy/.env.example - GCPデプロイ用環境変数テンプレート
# =====================================================
# コピーして .env を作成: cp deploy/.env.example deploy/.env

# ── GCP設定 ──────────────────────────────────────────
GCP_PROJECT=aiyagami
GCP_REGION=asia-northeast1
SERVICE_NAME=sena3fx-trader
GCS_BUCKET=sena3fx-paper-trading
SCHEDULER_NAME=sena3fx-run-cycle

# ── ブローカー選択 ──────────────────────────────────────
# "oanda"  = OANDAペーパートレード（デフォルト）
# "exness" = Exness本番取引（MetaApi経由）
BROKER=oanda

# ── OANDA設定（BROKER=oanda の場合） ────────────────────
OANDA_TOKEN=b3c7db048d5b6d1ac77e4263bd8bfb8b-1222fbcaf7d9ffe642692a226f7e7467
OANDA_ACCOUNT=101-009-38652105-001

# ── Exness設定（BROKER=exness の場合） ──────────────────
# MetaApi (https://metaapi.cloud) でアカウント作成が必要
# 1. https://app.metaapi.cloud にサインアップ
# 2. MT5アカウントを追加（Exness-MT5Real3, ログイン, パスワード）
# 3. APIトークンとアカウントIDをここに設定
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
EQUITY_JPY=1000000

# ── Discord通知 ─────────────────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/1329418335259197490/59-rzRn2tvHmvMetqMlJPtoo4CApLk3yGoBZoTfUexmXQzrUrTBI1X8sL7RbFfvoQG5k
